            "type":"service",
            "source":"/!/stat/st-producto-cc/?_act=buscar-linea&search=@search",
            "keyfield":"codigo",
            "searchfield":"codigo",
            "showfield":"descripcion",
            "columns":"codigo,descripcion",
            "ccaptions":"Código,Descripción"
