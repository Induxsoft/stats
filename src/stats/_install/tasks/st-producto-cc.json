        }
    },
    "cl": {
        "control":"select",
        "caption":"Clase:",
        "source": {
            "type":"query",
            "query":"select id, const from cclaseproducto where id > 1 and id < 7",
            "keyfield":"const", "showfield":"const",
            "first_value":"*", "first_text":"Todos"
        },
        "wrp_attr": {
            "class":"col-sm-8 col-md-6",
            "title":"Clase de producto que puede venderse."
        }
    },
    "ln": {
        "control":"input-key",
        "caption":"Línea:",
