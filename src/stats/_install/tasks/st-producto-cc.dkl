                @"devscompras": @@(d,"devoluciones")
                @"impdevcompras": @@(d,"importe")
                @"impuestos_devcompras": @@(d,"impuestos")
            }

            output<key+"*"> : data
        }
    }

    function _extractPedidosPorLlegar(&db,&params,&output)
    {
        condition = @@(params,"$condition")
        sql = ftext("
        SELECT
            IFNULL(cc.codigo,'') AS `cconsumo`,
            DATE_FORMAT(c.fecha,'%Y-%m-%d') AS fecha,
            SUM(d.factor * d.cantidad) AS por_llegar
        FROM dcompra d
            INNER JOIN compra c ON d.fk_compra_detalle = c.sys_pk
            INNER JOIN almacen a ON c.ialmacen = a.sys_pk
            LEFT JOIN cconsumo cc ON cc.ialmacen = a.sys_pk
        WHERE
            #<condition>
            AND c.documento = #<@cPedido>
            AND c.statusadministrativo = 3
            AND d.`status` = 1
        GROUP BY c.fecha, cc.codigo
        ORDER BY c.fecha
        ")
        ref pedidos_por_llegar = dbr.list(db,sql,params)
        for i = 0; i < list.count(pedidos_por_llegar)
        {
            ref p = list.obj(pedidos_por_llegar,i)

            cconsumo = @@(p,"$cconsumo")
            fecha = @@(p,"fecha")
            key = cconsumo + replace(fecha,"-","")

            ref data = @@(output,"&"+key)
            if isnull(data)
            {
                ref data:record.create()
                using
                {
                    @"cc": cconsumo
                    @"fecha": fecha
                }
            }
            data<"pedidos_por_llegar"> : @@(p,"por_llegar")

            output<key+"*"> : data
        }
    }

    function ExtractCardexStatistics(&db,&params)
    {
        sql = ftext("
        SELECT
            IFNULL(cc.codigo,'') AS `cconsumo`,
            DATE_FORMAT(c.fecha,'%Y-%m-%d') AS fecha,
            SUM(IFNULL(d.entradas,0)) AS entradas,
            SUM(IFNULL(d.salidas,0)) AS salidas,
            SUM(IFNULL(d.cargos,0)) AS cargos,
            SUM(IFNULL(d.abonos,0)) AS abonos,
            (select sum(ifnull(_d.entradas,0)) - sum(ifnull(_d.salidas,0))
            from dcardex _d
                inner join cardex _c on _d.fk_cardex_movimientos = _c.sys_pk
            where
                ifnull(_c.aplicado,0)
                and _d.iproducto = d.iproducto
                and _c.fecha <= c.fecha
            ) AS existencia
        FROM dcardex d
            INNER JOIN cardex c ON d.fk_cardex_movimientos = c.sys_pk
            INNER JOIN almacen a ON d.ialmacen = a.sys_pk
            LEFT JOIN cconsumo cc ON cc.ialmacen = a.sys_pk
        WHERE
            (CASE
                WHEN @fi != '' AND @ff != '' THEN c.fecha BETWEEN DATE(@fi) AND DATE(@ff)
                WHEN @fi != '' AND @ff = '' THEN c.fecha >= DATE(@fi)
                WHEN @fi = '' AND @ff != '' THEN c.fecha <= DATE(@ff)
                WHEN @da > 0 THEN c.fecha BETWEEN ADDDATE(CURDATE(), INTERVAL -@da DAY) AND CURDATE()
                ELSE TRUE
            END)
            AND IFNULL(c.aplicado,0)
            AND (@cc = '' OR IFNULL(cc.codigo,'') = @cc)
            AND d.iproducto = @iproducto
        GROUP BY c.fecha, cc.codigo
        ORDER BY c.fecha
        ")
        ref movimientos = dbr.list(db,sql,params)

        ref response = record.create()
        for i = 0; i < list.count(movimientos)
        {
            ref m = list.obj(movimientos,i)

            cconsumo = @@(m,"$cconsumo")
            fecha = @@(m,"$fecha")
            key = cconsumo + replace(fecha,"-","")

            new data
            {
                @"cc": cconsumo
                @"fecha": fecha
                @"entradas": @@(m,"#entradas")
                @"salidas": @@(m,"#salidas")
                @"cargos": @@(m,"#cargos")
                @"abonos": @@(m,"#abonos")
                @"existencia": @@(m,"#existencia")
            }

            response<key+"*"> : data
        }
        return response
    }

    function ExtractCompraStatistics(&db,&params)
    {
        ref response = record.create()
        condition = ftext("
            (CASE
                WHEN @fi != '' AND @ff != '' THEN c.fecha BETWEEN DATE(@fi) AND DATE(@ff)
                WHEN @fi != '' AND @ff = '' THEN c.fecha >= DATE(@fi)
                WHEN @fi = '' AND @ff != '' THEN c.fecha <= DATE(@ff)
                WHEN @da > 0 THEN c.fecha BETWEEN ADDDATE(CURDATE(), INTERVAL -@da DAY) AND CURDATE()
                ELSE TRUE
            END)
            AND (@cc = '' OR IFNULL(cc.codigo,'') = @cc)
            AND d.iproducto = @iproducto
        ")

        params<"condition"> : condition

        do _extractCompras(db,params,response)
        do _extractDevsCompra(db,params,response)
        do _extractPedidosPorLlegar(db,params,response)
        do field.remove(params,"condition")

        return response
    }

    function ExtractVentaStatistics(&db,&params)
    {
        ref response = record.create()
        condition = ftext("
            (CASE
                WHEN @fi != '' AND @ff != '' THEN v.fecha BETWEEN DATE(@fi) AND DATE(@ff)
                WHEN @fi != '' AND @ff = '' THEN v.fecha >= DATE(@fi)
                WHEN @fi = '' AND @ff != '' THEN v.fecha <= DATE(@ff)
                WHEN @da > 0 THEN v.fecha BETWEEN ADDDATE(CURDATE(), INTERVAL -@da DAY) AND CURDATE()
                ELSE TRUE
            END)
            AND (@cc = '' OR cc.codigo = @cc)
            AND d.iproducto = @iproducto
        ")
        
        params<"condition"> : condition

        do _extractVentas(db,params,response)
        do _extractDevsVenta(db,params,response)
        do _extractPedidosPorSurtir(db,params,response)
        do field.remove(params,"condition")

        return response
    }

    function SaveProductStat(&db,&params,&product)
    {
        params<"iproducto"> : @@(product,"sys_pk")

        ref cardex_stat = ExtractCardexStatistics(db,params)
        ref compra_stat = ExtractCompraStatistics(db,params)
        ref ventas_stat = ExtractVentaStatistics(db,params)

        cdx_stat_length = list.count(list.create_from_fields(cardex_stat))
        cmp_stat_length = list.count(list.create_from_fields(compra_stat))
        vnt_stat_length = list.count(list.create_from_fields(ventas_stat))
        max = 0
        codigo = @@(product,"codigo")
        unidad = @@(product,"unidad")
        divisa = @@(product,"divisa")
        descripcion = @@(product,"descripcion")
        tablename = GetStatTable(db)

        if cdx_stat_length > max {
            ref keys = list.create_from_fields(cardex_stat)
            max = cdx_stat_length
        }
        if cmp_stat_length > max {
            ref keys = list.create_from_fields(compra_stat)
            max = cmp_stat_length
        }
        if vnt_stat_length > max {
            ref keys = list.create_from_fields(ventas_stat)
            max = vnt_stat_length
        }

        for i = 0; i < max
        {
            key = list.str(keys,i)
            new stat
            {
                @"sku": codigo
                @"unidad": unidad
                @"divisa": divisa
                @"descripcion": descripcion
            }

            switch max
            {
                case cdx_stat_length
                {
                    ref st_cardex = field.obj(cardex_stat,key)
                    ref st_venta = field.dobj(ventas_stat,key,record.create())
                    ref st_compra = field.dobj(compra_stat,key,record.create())
                    break
                }
                case cmp_stat_length
                {
                    ref st_compra = field.obj(compra_stat,key)
                    ref st_cardex = field.dobj(cardex_stat,key,record.create())
                    ref st_venta = field.dobj(ventas_stat,key,record.create())
                    break
                }
                case vnt_stat_length
                {
                    ref st_venta = field.obj(ventas_stat,key)
                    ref st_compra = field.dobj(compra_stat,key,record.create())
                    ref st_cardex = field.dobj(cardex_stat,key,record.create())
                    break
                }
            }

            ref stat:RecordCombine(stat,st_venta)
            ref stat:RecordCombine(stat,st_compra)
            ref stat:RecordCombine(stat,st_cardex)

            do InsertOrUpdate(db,tablename,stat)
        }
    }

    function GetProducts(&db,&params)
    {
        sql = "
        SELECT DISTINCT
            p.sys_pk,
            p.codigo,
            p.descripcion,
            p.unidad,
            p.existencia,
            dv.codigo AS `divisa`,
            dv.tcambio
        FROM producto p
            INNER JOIN divisa dv ON p.idivisa = dv.sys_pk
            INNER JOIN cclaseproducto cl ON p.iclase = cl.id
            INNER JOIN linea ln ON p.ilinea = ln.sys_pk
            LEFT JOIN marca mr ON p.imarca = mr.sys_pk
            LEFT JOIN departamento dp ON p.idepartamento = dp.sys_pk
            LEFT JOIN grupoproductos_producto_ gpp ON gpp.iproductos = p.sys_pk
            LEFT JOIN grupoproductos gp ON gpp.igrupos = gp.sys_pk
        WHERE
            NOT IFNULL(p.sys_deleted,0)
            AND IF(@cl = '', (cl.id > 1 AND cl.id < 7), cl.const = @cl)
            AND (@ln = '' OR ln.codigo = @ln)
            AND (@mr = '' OR IFNULL(mr.codigo,'') = @mr)
            AND (@dp = '' OR IFNULL(dp.codigo,'') = @dp)
            AND (@gp = '' OR IFNULL(gp.nombre,'') = @gp)
            AND (@sku = '' OR p.codigo = @sku)
        "
        return dbr.list(db,sql,params)
    }

    function ExtractStatistics(&db,&params)
    {
        ref products = GetProducts(db,params)
        
        length = list.count(products)
        if length < 1 {
            do Log("No se encontraron productos con los parámetros proporcionados.")
            do Log(to.json(params))
            do UpdatePercent(100)
            return
        }
        
        progress = (100 / length)
        affected_rows = 0
        percent = 0

        for i = 0; i < length
        {
            ref product = list.obj(products,i)

            do Log("+ " + @@(product,"codigo") +" - "+ @@(product,"descripcion"))
            do SaveProductStat(db,params,product)

            affected_rows = affected_rows + 1

            exception
            {
                code = last_error_code()
                error = last_error()

                do pop_exception()
                do Log(" * "+error)
            }

            percent = percent + progress
            // do Log("En proceso ..."+str(percent)+"%")
            do UpdatePercent(percent)
        }

        do Log("** Productos analizados ("+str(affected_rows)+"/"+str(length)+")")
    }

    function ValidateParams(&params)
    {
        da = abs(@@(params,"#da"))
        fi = DateFormat(@@(params,"$fi"),"yyyy-MM-dd")
        ff = DateFormat(@@(params,"$ff"),"yyyy-MM-dd")
        cl = trim(@@(params,"$cl"))
        ln = trim(@@(params,"$ln"))
        mr = trim(@@(params,"$mr"))
        dp = trim(@@(params,"$dp"))
        gp = trim(@@(params,"$gp"))
        cc = trim(@@(params,"$cc"))
        sku = trim(@@(params,"$sku"))

        if da == 0 && fi == "" && ff == "" { do rise_error(99,"Debe indicar al menos uno de los siguientes argumentos: 'da','fi','ff'.") }
        if cl == "*" || val(cl) == -1 { cl = "" }
        if ln == "*" || val(ln) == -1 { ln = "" }
        if mr == "*" || val(mr) == -1 { mr = "" }
        if dp == "*" || val(dp) == -1 { dp = "" }
        if gp == "*" || val(gp) == -1 { gp = "" }
        if cc == "*" || val(cc) == -1 { cc = "" }
        if sku == "*" || val(sku) == -1 { sku = "" }

        using params
        {
            @"da": da
            @"fi": fi
            @"ff": ff
            @"cl": cl
            @"ln": ln
            @"mr": mr
            @"dp": dp
            @"gp": gp
            @"cc": cc
            @"sku": sku
        }
    }
    //#endregion

    //#region >INICIO
    if isset("@batch_context")
    {
        ref params = @("&params")
        ref db = @("&database")
        do batch.v12.grant(@_action_id)
    }
    else
    {
        ref params = commandline("=")
        ref db = dbr.open(@@(params,"$qn"))
    }

    do Log("> Extracción de estadísticas.")

    do ValidateParams(params)
    do EnsureStatTable(db)
    do ExtractStatistics(db,params)

    // do Log("**Operación completada.")

    exception
    {
        code = last_error_code()
        error = last_error()

        if isset("db")
        {
            if dbr.in_transaction(db){ do dbr.rollback(db) }
            if not(isset("@batch_context")) { do dbr.close(db) }
        }
        
        if not(isset("@batch_context")) { do PrintError(error) }
        else { do rise_error(code,error) }
    }
    //#endregion

    do @context.end()
}