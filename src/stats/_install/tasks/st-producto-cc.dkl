            key = cconsumo + replace(fecha,"-","")

            ref data = @@(output,"&"+key)
            if isnull(data)
            {
                ref data:record.create()
                using
                {
                    @"cc": cconsumo
                    @"fecha": fecha
                }
            }
            using data
