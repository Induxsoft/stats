#include "dkli.dkh"
#!
program "Extracción de estadísticas diarias de productos por centro de consumo"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "dbr.dkh"
    
    if isset("@batch_context")
    {
        #include "dbr.apps.dkl"
        #include "dbr.security.dkl"
        #include "dbr.vars.dkl"
        #include "batch.v12.dkl"

        do @context.begin(@batch_context)
    }

    //#region >CONSTANTES
    do errordet(@false)

    @_action_id = ""
    @default_table_name = "st_producto_cc"
    @convertir_a_divisa_producto = 1
    @convertir_a_divisa_documento = 2
    // cdocumentos (tipos de documentos comerciales)
    @cCotizacion = 1
    @cPedido = 2
    @cRemision = 3
    @cFactura = 4
    @cNotaCredito = 5
    @cTicket = 6
    @cNotaCargo = 17
    @cDeposito = 65
    @cRetiro = 67

    @_sql_create_table = "
    CREATE TABLE IF NOT EXISTS `#<tablename>` (
        `sys_dtcreated` DATETIME NOT NULL /*!50605 DEFAULT CURRENT_TIMESTAMP */ COMMENT 'Fecha de creación del registro de estadística',
        `sys_timestamp` DATETIME NOT NULL /*!50605 DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP */ COMMENT 'Fecha de actualización de la estadística',
        
        `cc` VARCHAR(5) NOT NULL COMMENT 'Código de centro de consumo',
        `fecha` DATE NOT NULL COMMENT 'Fecha (día de la estadística)',
        `sku` VARCHAR(35) NOT NULL COMMENT 'Código del producto',
        `unidad` VARCHAR(10) NOT NULL COMMENT 'Unidad estándar del producto',
        `divisa` VARCHAR(5) NOT NULL COMMENT 'Código de la divisa del producto (todos los importes en esta divisa)',
        `descripcion` TEXT,
        
        `existencia` INT(11) DEFAULT 0 COMMENT 'Existencia total en ese día',
        `entradas` INT(11) DEFAULT 0 COMMENT 'Entradas de almacén en el día',
        `salidas` INT(11) DEFAULT 0 COMMENT 'Salidas de almacén en el día',
        `cargos` DECIMAL(18,8) DEFAULT 0 COMMENT 'Costo de todas las entradas del día',
        `abonos` DECIMAL(18,8) DEFAULT 0 COMMENT 'Costo de todas las salidas del día',
        
        `ventas` INT(11) DEFAULT 0 COMMENT 'Cantidad de unidades vendidas',
        `costoventas` DECIMAL(18,8) DEFAULT 0 COMMENT 'Costo de las ventas del día',
        `impventas` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de las ventas del día',
        `impuestos_ventas` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de impuestos sobre ventas',
        `devsventas` INT(11) DEFAULT 0 COMMENT 'Cantidad de unidades por devoluciones sobre ventas',
        `costodevventas` DECIMAL(18,8) DEFAULT 0 COMMENT 'Costo de las devoluciones sobre ventas del día',
        `impdevventas` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de las devoluciones sobre ventas',
        `impuestos_devventas` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de impuestos por devoluciones sobre ventas',
        `opventas` INT(11) DEFAULT 0 COMMENT 'Cantidad de operaciones de venta de este producto en el día',
        `opclientes` INT(11) DEFAULT 0 COMMENT 'Cantidad de clientes que compraron este producto en el día',
        `pedidos_por_surtir` INT(11) DEFAULT 0 COMMENT 'Cantidad de unidades por entregar (pedidos)',
        
        `compras` INT(11) DEFAULT 0 COMMENT 'Cantidad de unidades compradas',
        `impcompras` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de las compras del día',
        `impuestos_compras` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de impuestos sobre compras',
        `devscompras` INT(11) DEFAULT 0 COMMENT 'Cantidad de unidades por devoluciones sobre compras',
        `impdevcompras` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de las devoluciones sobre compras',
        `impuestos_devcompras` DECIMAL(18,8) DEFAULT 0 COMMENT 'Importe de impuestos por devoluciones sobre compras',
        `pedidos_por_llegar` INT(11) DEFAULT 0 COMMENT 'Cantidad de unidades por recibir (pedidos)',
        
        KEY `cc` (`cc`),
        KEY `fecha` (`fecha`),
        KEY `sku` (`sku`),
        UNIQUE KEY `uk_producto_cc` (`cc`,`fecha`,`sku`,`unidad`,`divisa`)
    )
    ENGINE=InnoDB
    DEFAULT CHARSET=latin1
    COLLATE='latin1_swedish_ci'
    ;"
    //#endregion

    //#region >FUNCIONES
    function PrintError(error)
    {
        do print("")
        do print("-  ERROR -")
        do print(error)
        do print("------------------------------------------------------------")
        do print("")
        do print("- USO DE LA HERRAMIENTA -")
        do print('./dkl st-producto-cc qn="miconexion@grupoapps" ...argumentos')
        do print("")
        do print("[Argumentos]")
        do print("qn = Nombre cualificado de conexión a la base de datos.")
        do print("da = Número de días anteriores a 'hoy'.")
        do print("fi = Fecha de inicio de recopilación de datos.")
        do print("ff = Fecha final de recopilación de datos.")
        do print("cl = Clase de producto que puede venderse.")
        do print("ln = Código de una línea de productos.")
        do print("mr = Código de una marca de productos.")
        do print("dp = Código de un departamento de productos.")
        do print("gp = Nombre de un grupo de productos.")
        do print("cc = Código de un centro de consumo.")
        do print("sku = Código de un producto.")
        do print("------------------------------------------------------------")
    }

    function RecordCombine(&rec1,&rec2)
    {
        return record.copyexin(rec2,rec1,"*",",","",":")
    }

    function DateFormat(dtm,fmt)
    {
        if dtm == "" { return "" }
        if fmt == "" { fmt = "yyyy-MM-dd HH:mm:ss" }

        fecha = date_str(str2dt(dtm),fmt)
        return fecha

        exception
        {
            do pop_exception()
            do rise_error(99,"Debe indicar una fecha válida.")
        }
    }

    function ConvertirADivisa(value,tcprd,tcdoc,mode)
    {
        if mode == @convertir_a_divisa_producto {
            return div((value * tcdoc), tcprd)
        }
        if mode == @convertir_a_divisa_documento {
            return div((value * tcprd), tcdoc)
        }

        return value
    }

    function Log(text)
    {
        if isset("@batch_context") { do batch.saveLog(@("$job/token"),text) }
        else { do print(text) }
    }

    function UpdatePercent(value)
    {
        if not(isset("@batch_context")) { return }

        new params
        {
            @"token":@("$job/token")
        }
        new data
        {
            @"percentage":value
            @"progress_type":2
        }
        do dbr.update(batch.openDB(),"job",data,"sys_guid=@token",params)
    }

    function InsertOrUpdate(&db,tablename,&data)
    {
        ref fields=list.create_from_fields(data)
        str_fields=replace(ranychars(to.json(fields),'[]{}"', " ")," ","")

        sql="INSERT INTO "+tablename+" (sys_dtcreated,sys_timestamp,"+str_fields+") VALUES (NOW(),NOW(),"

        for i=0; i<list.count(fields) {
            if i>0 { sql=sql+"," }
            sql=sql+"@"+list.str(fields,i)
        }

        sql=sql+") ON DUPLICATE KEY UPDATE sys_timestamp=NOW(),"

        for i=0; i<list.count(fields) {
            field=list.str(fields,i)
            if i>0 { sql=sql+"," }
            sql=sql+field+"=@"+field
        }

        sql=sql+";"
        return dbr.execute(db, sql, data)
    }

    function GetStatTable(&db)
    {
        tbn_st_producto_cc = ""

        if not(isset("@batch_context")) { tbn_st_producto_cc = @default_table_name }
        else
        {
            tbn_st_producto_cc = dbr.vars.getd(db,"tbn_st_producto_cc",@default_table_name)
            if tbn_st_producto_cc == "" { tbn_st_producto_cc = @default_table_name }
        }

        return tbn_st_producto_cc
    }

    function EnsureStatTable(&db)
    {
        tablename = GetStatTable(db)
        do dbr.execute(db,ftext(@_sql_create_table),@null)
    }

    function _extractVentas(&db,&params,&output)
    {
        condition = @@(params,"$condition")
        sql = ftext("
        SELECT
            cc.codigo AS `cconsumo`,
            DATE_FORMAT(v.fecha,'%Y-%m-%d') AS fecha,
            SUM(d.factor * d.cantidad) AS ventas,
            COUNT(v.sys_pk) AS opventas,
            COUNT(DISTINCT v.icliente) AS opclientes,
            ((SUM(d.precio * d.cantidad) * v.tipocambio) / dp.tcambio) AS subtotal,
            ((SUM(d.descuento1 + d.descuento2) * v.tipocambio) / dp.tcambio) AS descuentos,
            ((SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4) * v.tipocambio) / dp.tcambio) AS impuestos,
            (((SUM(d.precio * d.cantidad)
                - SUM(d.descuento1 + d.descuento2)
                + SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4)
            ) * v.tipocambio) / dp.tcambio) AS importe,
            (SUM(d.factor * d.cantidad) * p.costoultimo) AS costoventas
        FROM dventa d
            INNER JOIN producto p ON d.iproducto = p.sys_pk
            INNER JOIN divisa dp ON p.idivisa = dp.sys_pk
            INNER JOIN venta v ON d.fk_venta_detalle = v.sys_pk
            INNER JOIN cconsumo cc ON v.icconsumo = cc.sys_pk
            LEFT JOIN venta o ON d.documento = o.sys_pk
        WHERE
            #<condition>
            AND (v.documento IN (#<@cRemision>,#<@cTicket>) OR (v.documento = #<@cFactura> AND (d.documento IS NULL OR o.documento IN(#<@cCotizacion>,#<@cPedido>))))
            AND v.statusadministrativo = 3
        GROUP BY v.fecha, cc.codigo
        ORDER BY v.fecha
        ")
        ref ventas = dbr.list(db,sql,params)
        for i = 0; i < list.count(ventas)
        {
            ref v = list.obj(ventas,i)

            cconsumo = @@(v,"cconsumo")
            fecha = @@(v,"fecha")
            key = cconsumo + replace(fecha,"-","")

            new data
            {
                @"cc": cconsumo
                @"fecha": fecha
                @"ventas": @@(v,"ventas")
                @"opventas": @@(v,"opventas")
                @"opclientes": @@(v,"opclientes")
                @"impventas": @@(v,"importe")
                @"impuestos_ventas": @@(v,"impuestos")
                @"costoventas": @@(v,"costoventas")
            }

            output<key+"*"> : data
        }
    }

    function _extractDevsVenta(&db,&params,&output)
    {
        condition = @@(params,"$condition")
        sql = ftext("
        SELECT
            cc.codigo AS `cconsumo`,
            DATE_FORMAT(v.fecha,'%Y-%m-%d') AS fecha,
            SUM(d.factor * d.cantidad) AS devoluciones,
            COUNT(v.sys_pk) AS opventas,
            COUNT(DISTINCT v.icliente) AS opclientes,
            ((SUM(d.precio * d.cantidad) * v.tipocambio) / dp.tcambio) AS subtotal,
            ((SUM(d.descuento1 + d.descuento2) * v.tipocambio) / dp.tcambio) AS descuentos,
            ((SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4) * v.tipocambio) / dp.tcambio) AS impuestos,
            (((SUM(d.precio * d.cantidad)
                - SUM(d.descuento1 + d.descuento2)
                + SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4)
            ) * v.tipocambio) / dp.tcambio) AS importe,
            (SUM(d.factor * d.cantidad) * p.costoultimo) AS costodevventas
        FROM dventa d
            INNER JOIN producto p ON d.iproducto = p.sys_pk
            INNER JOIN divisa dp ON p.idivisa = dp.sys_pk
            INNER JOIN venta v ON d.fk_venta_detalle = v.sys_pk
            INNER JOIN cconsumo cc ON v.icconsumo = cc.sys_pk
            LEFT JOIN venta o ON d.documento = o.sys_pk
        WHERE
            #<condition>
            AND v.documento = #<@cNotaCredito>
            AND v.statusadministrativo = 3
        GROUP BY v.fecha, cc.codigo
        ORDER BY v.fecha
        ")
        ref devsventas = dbr.list(db,sql,params)
        for i = 0; i < list.count(devsventas)
        {
            ref d = list.obj(devsventas,i)

            cconsumo = @@(d,"cconsumo")
            fecha = @@(d,"fecha")
            key = cconsumo + replace(fecha,"-","")

            ref data = @@(output,"&"+key)
            if isnull(data)
            {
                ref data:record.create()
                using
                {
                    @"cc": cconsumo
                    @"fecha": fecha
                }
            }
            using data
            {
                @"devsventas": @@(d,"devoluciones")
                @"impdevventas": @@(d,"importe")
                @"impuestos_devventas": @@(d,"impuestos")
                @"costodevventas": @@(d,"costodevventas")
            }

            output<key+"*"> : data
        }
    }

    function _extractPedidosPorSurtir(&db,&params,&output)
    {
        condition = @@(params,"$condition")
        sql = ftext("
        SELECT
            IFNULL(cc.codigo,'') AS `cconsumo`,
            DATE_FORMAT(v.fecha,'%Y-%m-%d') AS fecha,
            SUM(d.factor * d.cantidad) AS por_surtir
        FROM dventa d
            INNER JOIN venta v ON d.fk_venta_detalle = v.sys_pk
            INNER JOIN cconsumo cc ON v.icconsumo = cc.sys_pk
        WHERE
            #<condition>
            AND v.documento = #<@cPedido>
            AND v.statusadministrativo = 3
            AND d.`status` = 1
        GROUP BY v.fecha, cc.codigo
        ORDER BY v.fecha
        ")
        ref pedidos_por_surtir = dbr.list(db,sql,params)
        for i = 0; i < list.count(pedidos_por_surtir)
        {
            ref p = list.obj(pedidos_por_surtir,i)

            cconsumo = @@(p,"$cconsumo")
            fecha = @@(p,"fecha")
            key = cconsumo + replace(fecha,"-","")

            ref data = @@(output,"&"+key)
            if isnull(data)
            {
                ref data:record.create()
                using
                {
                    @"cc": cconsumo
                    @"fecha": fecha
                }
            }
            data<"pedidos_por_surtir"> : @@(p,"por_surtir")

            output<key+"*"> : data
        }
    }

    function _extractCompras(&db,&params,&output)
    {
        condition = @@(params,"$condition")
        sql = ftext("
        SELECT
            IFNULL(cc.codigo,'') AS `cconsumo`,
            DATE_FORMAT(c.fecha,'%Y-%m-%d') AS fecha,
            SUM(d.factor * d.cantidad) AS compras,
            COUNT(c.sys_pk) AS opcompras,
            COUNT(DISTINCT c.iproveedor) AS opproveedores,
            ((SUM(d.precio * d.cantidad) * c.tipocambio) / dp.tcambio) AS subtotal,
            ((SUM(d.descuento1 + d.descuento2) * c.tipocambio) / dp.tcambio) AS descuentos,
            ((SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4) * c.tipocambio) / dp.tcambio) AS impuestos,
            (((SUM(d.precio * d.cantidad)
                - SUM(d.descuento1 + d.descuento2)
                + SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4)
            ) * c.tipocambio) / dp.tcambio) AS importe
        FROM dcompra d
            INNER JOIN producto p ON d.iproducto = p.sys_pk
            INNER JOIN divisa dp ON p.idivisa = dp.sys_pk
            INNER JOIN compra c ON d.fk_compra_detalle = c.sys_pk
            INNER JOIN almacen a ON c.ialmacen = a.sys_pk
            LEFT JOIN cconsumo cc ON cc.ialmacen = a.sys_pk
            LEFT JOIN compra o ON d.documento = o.sys_pk
        WHERE
            #<condition>
            AND (c.documento = #<@cRemision> OR (c.documento = #<@cFactura> AND (d.documento IS NULL OR o.documento IN(#<@cCotizacion>,#<@cPedido>))))
            AND c.statusadministrativo = 3
        GROUP BY c.fecha, cc.codigo
        ORDER BY c.fecha
        ")
        ref compras = dbr.list(db,sql,params)
        for i = 0; i < list.count(compras)
        {
            ref c = list.obj(compras,i)

            cconsumo = @@(c,"$cconsumo")
            fecha = @@(c,"fecha")
            key = cconsumo + replace(fecha,"-","")

            new data
            {
                @"cc": cconsumo
                @"fecha": fecha
                @"compras": @@(c,"compras")
                @"impcompras": @@(c,"importe")
                @"impuestos_compras": @@(c,"impuestos")
            }

            output<key+"*"> : data
        }
    }

    function _extractDevsCompra(&db,&params,&output)
    {
        condition = @@(params,"$condition")
        sql = ftext("
        SELECT
            IFNULL(cc.codigo,'') AS `cconsumo`,
            DATE_FORMAT(c.fecha,'%Y-%m-%d') AS fecha,
            SUM(d.factor * d.cantidad) AS devoluciones,
            COUNT(c.sys_pk) AS opcompras,
            COUNT(DISTINCT c.iproveedor) AS opproveedores,
            ((SUM(d.precio * d.cantidad) * c.tipocambio) / dp.tcambio) AS subtotal,
            ((SUM(d.descuento1 + d.descuento2) * c.tipocambio) / dp.tcambio) AS descuentos,
            ((SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4) * c.tipocambio) / dp.tcambio) AS impuestos,
            (((SUM(d.precio * d.cantidad)
                - SUM(d.descuento1 + d.descuento2)
                + SUM(d.impuesto1 + d.impuesto2 + d.impuesto3 + d.impuesto4)
            ) * c.tipocambio) / dp.tcambio) AS importe
        FROM dcompra d
            INNER JOIN producto p ON d.iproducto = p.sys_pk
            INNER JOIN divisa dp ON p.idivisa = dp.sys_pk
            INNER JOIN compra c ON d.fk_compra_detalle = c.sys_pk
            INNER JOIN almacen a ON c.ialmacen = a.sys_pk
            LEFT JOIN cconsumo cc ON cc.ialmacen = a.sys_pk
